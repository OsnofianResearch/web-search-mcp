{\n  "name": "@asdrubalinasmyth/web-search-mcp",\n  "version": "1.0.5",\n  "type": "module",\n  "description": "MCP server to search the web and fetch page contents",\n  "bin": {\n    "web-search-mcp": "dist/server.js"\n  },\n  "scripts": {\n    "start": "tsx src/server.ts",\n    "clean": "rimraf dist",\n    "build": "npm run clean && tsc -p tsconfig.build.json",\n    "lint": "eslint .",\n    "test": "vitest run",\n    "check": "tsc -p tsconfig.json --noEmit && eslint . && vitest run",\n    "smoke": "tsx scripts/smoke.ts"\n  },\n  "engines": {\n    "node": ">=20"\n  },\n  "files": [\n    "dist",\n    "README.md",\n    "LICENSE"\n  ],\n  "publishConfig": {\n    "access": "public"\n  },\n  "prepare": "npm run build",\n  "repository": {\n    "type": "git",\n    "url": "git+https://github.com/OsnofianResearch/web-search-mcp.git"\n  },\n  "bugs": {\n    "url": "https://github.com/OsnofianResearch/web-search-mcp/issues"\n  },\n  "homepage": "https://github.com/OsnofianResearch/web-search-mcp#readme",\n  "keywords": [\n    "mcp",\n    "modelcontextprotocol",\n    "web",\n    "search",\n    "scrape"\n  ],\n  "author": "",\n  "license": "MIT",\n  "dependencies": {\n    "@modelcontextprotocol/sdk": "^1.17.2",\n    "@mozilla/readability": "^0.6.0",\n    "jsdom": "^26.1.0",\n    "undici": "^7.13.0",\n    "zod": "^3.23.8"\n  },\n  "devDependencies": {\n    "@types/jsdom": "^21.1.7",\n    "@types/node": "^24.2.0",\n    "@typescript-eslint/eslint-plugin": "^8.39.0",\n    "@typescript-eslint/parser": "^8.39.0",\n    "eslint": "^9.32.0",\n    "globals": "^16.3.0",\n    "rimraf": "^6.0.1",\n    "tsx": "^4.20.3",\n    "typescript": "^5.9.2",\n    "vitest": "^3.2.4"\n  }\n}